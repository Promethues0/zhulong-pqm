# 烛龙 PQM 后端运行配置（EnvironmentFile）
# install.sh 首次安装时会把 __JWT_SECRET__ 替换为随机值。

# HTTP 监听端口（nginx 反代至此；建议防火墙仅放行回环）
ZPQM_PORT=8099

# SQLite 数据库路径（systemd WorkingDirectory=/var/lib/zhulong-pqm）
ZPQM_DB_PATH=/var/lib/zhulong-pqm/zhulong-pqm.db

# JWT 签名密钥 —— 生产务必使用随机值，切勿用开发默认值
ZPQM_JWT_SECRET=__JWT_SECRET__
